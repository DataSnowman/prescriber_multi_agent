# ── Fabric Data Agent (existing) ──────────────────────────────
TENANT_ID=<your-tenant-id>
DATA_AGENT_URL=<your-data-agent-url>

# ── Azure AI Foundry (orchestrator LLM) ──────────────────────
# Get these from Azure AI Foundry → your project → Deployments
FOUNDRY_PROJECT_ENDPOINT=<your-foundry-project-endpoint>
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4.1

# ── Server / Azure Container Apps (optional) ─────────────────
# PORT is set automatically by Azure Container Apps; override
# locally if needed.  When PORT is set the app defaults to
# server mode (no --server flag required).
# PORT=8080
